N <- 200
G <- 20
set.seed(1234)
alpha <- 0
beta <- c(1,1)
sigma <- 4
tau <- 2
r <- rnorm(G,0,1)
P <- length(beta)
GID <- rep(1,N/G)
for(i in 2:G){
GID <- c(GID,rep(i,N/G))
}
x1 <- rnorm(N,0,2)
x2 <- rnorm(N,0,2)
X <- cbind(x1,x2)
mu <- alpha + X%*%beta + r[GID]*tau
Y <- rnorm(N,mu,sigma)
tau_prior <- 10
dat.HLM <- list(P = P,
GID = GID,
Y = Y,
X = X)
par.HLM <- list(
alpha = Dim(),
beta = Dim(dim = P),
tau = Dim(lower = 0),
sigma = Dim(lower = 0),
r = Dim(dim = G, random = TRUE)
)
model.HLM <- model_code({
mu <- alpha + X %*% beta + r[GID] * tau
Y ~ normal(mu, sigma)
r ~ normal(0, 1)
alpha ~ normal(0, 10)
beta ~ normal(0, 10)
sigma ~ exponential(1 / 10)
tau ~ exponential(1 / 10)
})
log_prob.HLM <- function(dat,par){
getAll(dat, par)
mu <- alpha + X %*% beta + r[GID] * tau
lp <- 0
lp <- lp + normal_lpdf(Y, mu, sigma)
lp <- lp + normal_lpdf(r, 0, 1)
lp <- lp + normal_lpdf(alpha, 0, 10)
lp <- lp + normal_lpdf(beta, 0, 10)
lp <- lp + exponential_lpdf(sigma, 1/10)
lp <- lp + exponential_lpdf(tau, 1/tau_prior)
return(lp)
}
# HLM
mdl.HLM <- rtmb_model(dat.HLM,par.HLM,model.HLM)
# ラプラス近似によるMAP推定
opt.HLM <- mdl.HLM$optimize(laplace = TRUE)
opt.HLM$summary(digits = 2)
