Sigma <- Lambda %*% t(Lambda) + diag(psi)
item_sd <- sqrt(diag(Sigma))
Lambda_std <- Lambda / item_sd
communality <- rowSums(Lambda^2) / diag(Sigma)
Y_c <- t(t(Y) - mu)
theta <- Y_c %*% solve(Sigma, Lambda)
list(
Lambda_std = Lambda_std,
communality = communality,
theta = theta
)
})
