mean ~ normal(0, 10)
sd ~ exponential(10)
CF_corr ~ lkj_CF_corr(1)
S_mat ~ sufficient_multi_normal_CF(N, Y_bar, mean, sd, CF_corr)
})
gene_cor <- transformed_code({
corr <- CF_corr%*%t(CF_corr)
})
mdl_cor <-
rtmb_model(dat_cor, par_cor, model_cor, generate = gene_cor)
