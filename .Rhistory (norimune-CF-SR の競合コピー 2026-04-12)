set.seed(123)
N <- 200 # サンプルサイズ
D <- 4   # 次元数
# 真の相関行列 (対角成分は1、非対角成分は-1~1)
R_true <- matrix(c(
1.0,  0.6,  0.3, -0.4,
0.6,  1.0,  0.5, -0.2,
0.3,  0.5,  1.0,  0.1,
-0.4, -0.2,  0.1,  1.0
), nrow = D, ncol = D)
# 真の標準偏差
sigma_true <- c(1.0, 1.5, 0.8, 2.0)
# 真の分散共分散行列の構築: diag(sigma) %*% R %*% diag(sigma)
D_mat_true <- diag(sigma_true)
Sigma_true <- D_mat_true %*% R_true %*% D_mat_true
# 多変量正規分布からデータをサンプリング
Y_obs <- MASS::mvrnorm(N, mu = rep(0, D), Sigma = Sigma_true)
Y_bar <- apply(Y_obs,2,mean)
S_mat <- cov(Y_obs)*(N-1)
dat_cor <- list(
Y_bar = Y_bar,
S_mat = S_mat
)
par_cor <- list(
mean    = Dim(D),
sd      = Dim(D, lower = 0),
CF_corr = Dim(c(D, D), type = "CF_corr")
)
model_cor <- model_code({
mean ~ normal(0, 10)
sd ~ exponential(10)
CF_corr ~ lkj_CF_corr(1)
S_mat ~ sufficient_mvnorm_CF(N, Y_bar, mean, sd, CF_corr)
})
gene_cor <- transformed_code({
corr <- CF_corr%*%t(CF_corr)
})
mdl_cor <-
rtmb_model(dat_cor, par_cor, model_cor, generate = gene_cor)
