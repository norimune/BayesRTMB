set.seed(123)
N <- 200
J <- 15
K <- 3
# 単純構造の負荷量行列: 15項目 × 3因子
Lambda_true <- matrix(0, nrow = J, ncol = K)
Lambda_true[1:5,   1] <- 0.8
Lambda_true[6:10,  2] <- 0.8
Lambda_true[11:15, 3] <- 0.8
# 因子得点: N × 3
eta_true <- matrix(rnorm(N * K), nrow = N, ncol = K)
# 誤差標準偏差
sigma_true <- rep(sqrt(1 - 0.8^2), J)   # = 0.6
# 観測データ生成
mean <- eta_true %*% t(Lambda_true)       # N × J
Y <- mean + matrix(rnorm(N * J, 0, rep(sigma_true, each = N)),
nrow = N, ncol = J)
Y_bar <- apply(Y,2,mean)
S_Y <- cov(Y)*(N-1)
dat_fa <- list(
N     = N,
Y_bar = Y_bar,
S_Y   = S_Y
)
par_fa <- list(
mu = Dim(dim = J),
Lambda = Dim(dim = c(J, K), type = "CF_cov"),
psi = Dim(dim = J, lower = 0)
)
model_fa <- model_code({
S_Y ~ sufficient_multi_normal_fa(N, Y_bar, mu, psi, Lambda)
mu ~ normal(0, 10)
psi ~ exponential(1)
Lambda ~ positive_lower_tri_normal(0, 1)
})
eig <- eigen(S_Y)
L_pca <- eig$vectors[, 1:K] %*% diag(sqrt(eig$values[1:K]))
L_top <- L_pca[1:K, ]
qr_res <- qr(t(L_top))
Q_mat <- qr.Q(qr_res)
init_Lambda <- L_pca %*% Q_mat
for (k in 1:K) {
if (init_Lambda[k, k] < 0) {
init_Lambda[, k] <- -init_Lambda[, k]
}
}
init_psi <- diag(S_Y) - rowSums(init_Lambda^2)
# リストにまとめる
init_fa <- list(
mu     = Y_bar,
Lambda = init_Lambda,
psi    = init_psi
)
mdl_fa <- rtmb_model(dat_fa,
par_fa,
model_fa)
