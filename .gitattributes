# Keep package source files stable across platforms.
* text=auto eol=lf

# R package source and documentation should stay LF-normalized.
*.R text eol=lf
*.Rmd text eol=lf
*.Rd text eol=lf
*.md text eol=lf
DESCRIPTION text eol=lf
NAMESPACE text eol=lf
LICENSE text eol=lf
CRAN-SUBMISSION text eol=lf
inst/WORDLIST text eol=lf
.Rbuildignore text eol=lf
.gitignore text eol=lf
*.Rproj text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Data and generated image assets are binary.
*.rda binary
*.RData binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
